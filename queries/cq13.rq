# CQ13: Which record labels have signed artists spanning more than N distinct genres?
# Genre is on artists (mo:genre), not releases.
# Join: Artist -> mh:signedTo -> mh:RecordLabel + Artist -> mo:genre -> mo:Genre
# ?genre a mo:Genre filters a noise triple on Quincy Jones pointing to an album URI.
# Threshold N=5.

PREFIX dc:    <http://purl.org/dc/elements/1.1/>
PREFIX foaf:  <http://xmlns.com/foaf/0.1/>
PREFIX mb:    <http://musicbrainz.org/artist/>
PREFIX mb_recording: <http://musicbrainz.org/recording/>
PREFIX mh:    <http://example.org/music-history/>
PREFIX mo:    <http://purl.org/ontology/mo/>
PREFIX owl:   <http://www.w3.org/2002/07/owl#>
PREFIX rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX xsd:   <http://www.w3.org/2001/XMLSchema#>

SELECT ?labelName (COUNT(DISTINCT ?genre) AS ?genreCount)
WHERE {
    ?artist mh:signedTo ?label ;
            mo:genre ?genre .
    ?label a mh:RecordLabel ;
           rdfs:label ?labelName .
    ?genre a mo:Genre .
}
GROUP BY ?label ?labelName
HAVING(COUNT(DISTINCT ?genre) > 5)
ORDER BY DESC(?genreCount)
