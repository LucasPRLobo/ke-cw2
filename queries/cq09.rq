# CQ9: What subgenres emerged from a given genre?
# mh:subgenreOf is declared owl:TransitiveProperty but rdflib does NOT auto-infer
# transitivity -- use mh:subgenreOf+ property path for transitive closure.
# Self-loop exists: classical mh:subgenreOf classical -- excluded by FILTER.
# "jazz" has 10 subgenres; "rock" has 5.

PREFIX dc:    <http://purl.org/dc/elements/1.1/>
PREFIX foaf:  <http://xmlns.com/foaf/0.1/>
PREFIX mb:    <http://musicbrainz.org/artist/>
PREFIX mb_recording: <http://musicbrainz.org/recording/>
PREFIX mh:    <http://example.org/music-history/>
PREFIX mo:    <http://purl.org/ontology/mo/>
PREFIX owl:   <http://www.w3.org/2002/07/owl#>
PREFIX rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX xsd:   <http://www.w3.org/2001/XMLSchema#>

SELECT ?subgenreLabel
WHERE {
    ?parent a mo:Genre ;
            rdfs:label ?parentLabel .
    FILTER(STR(?parentLabel) = "jazz")
    ?sub mh:subgenreOf+ ?parent ;
         rdfs:label ?subgenreLabel .
    FILTER(?sub != ?parent)
}
ORDER BY ?subgenreLabel
