# CQ7: Who plays what instrument in a given band?
# Combines membership (UNION of mo:member_of and mh:hasMember) with mh:playsInstrument.
# Not all members have instrument data -- the inner join filters those without.
# The Beatles have members with drums, guitar, bass guitar, vocals, etc.

PREFIX dc:    <http://purl.org/dc/elements/1.1/>
PREFIX foaf:  <http://xmlns.com/foaf/0.1/>
PREFIX mb:    <http://musicbrainz.org/artist/>
PREFIX mb_recording: <http://musicbrainz.org/recording/>
PREFIX mh:    <http://example.org/music-history/>
PREFIX mo:    <http://purl.org/ontology/mo/>
PREFIX owl:   <http://www.w3.org/2002/07/owl#>
PREFIX rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX xsd:   <http://www.w3.org/2001/XMLSchema#>

SELECT DISTINCT ?memberName ?instrumentLabel
WHERE {
    ?band rdfs:label ?bandName .
    FILTER(STR(?bandName) = "The Beatles")
    {
        ?member mo:member_of ?band .
    }
    UNION
    {
        ?band mh:hasMember ?member .
    }
    ?member rdfs:label ?memberName ;
            mh:playsInstrument ?instrument .
    ?instrument rdfs:label ?instrumentLabel .
}
ORDER BY ?memberName ?instrumentLabel
