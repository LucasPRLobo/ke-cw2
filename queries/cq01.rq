# CQ1: What date was an album released?
# Returns all releases with their titles and release dates.
# releaseDate is always a plain string (never ^^xsd:date).
# Formats vary: "1969-11-04" (full), "1981" (year-only), "1957-09" (year-month).

PREFIX dc:    <http://purl.org/dc/elements/1.1/>
PREFIX foaf:  <http://xmlns.com/foaf/0.1/>
PREFIX mb:    <http://musicbrainz.org/artist/>
PREFIX mb_recording: <http://musicbrainz.org/recording/>
PREFIX mh:    <http://example.org/music-history/>
PREFIX mo:    <http://purl.org/ontology/mo/>
PREFIX owl:   <http://www.w3.org/2002/07/owl#>
PREFIX rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:  <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX xsd:   <http://www.w3.org/2001/XMLSchema#>

SELECT ?album ?title ?date
WHERE {
    ?album a mo:Release ;
           dc:title ?title ;
           mh:releaseDate ?date .
}
ORDER BY ?date
LIMIT 20
