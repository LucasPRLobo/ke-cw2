mo:member_of a owl:ObjectProperty ;
    rdfs:comment "[Music Ontology] Links an artist to a group they are a member of." .

mo:performer a owl:ObjectProperty ;
    rdfs:comment "[Music Ontology] Links a track or signal to its performer." .

mo:producer a owl:ObjectProperty ;
    rdfs:comment "[Music Ontology] Links a record to its producer." .

mo:publisher a owl:ObjectProperty ;
    rdfs:comment "[Music Ontology] Links a record to its record label." .

mo:release_date a owl:DatatypeProperty ;
    rdfs:comment "[Music Ontology] Release date of a record." .

mo:track a owl:ObjectProperty ;
    rdfs:comment "[Music Ontology] Links a record to its tracks." .

schema:MusicAlbum a owl:Class ;
    rdfs:comment "[Schema.org] A music album." .

schema:MusicComposition a owl:Class ;
    rdfs:comment "[Schema.org] A musical composition." .

schema:MusicRecording a owl:Class ;
    rdfs:comment "[Schema.org] A music recording (track)." .

schema:award a owl:ObjectProperty ;
    rdfs:comment "[Schema.org] An award won by or for this item." .

schema:birthDate a owl:DatatypeProperty ;
    rdfs:comment "[Schema.org] Date of birth." .

schema:datePublished a owl:DatatypeProperty ;
    rdfs:comment "[Schema.org] Date of first publication." .

schema:deathDate a owl:DatatypeProperty ;
    rdfs:comment "[Schema.org] Date of death." .

schema:gender a owl:DatatypeProperty ;
    rdfs:comment "[Schema.org] Gender of a person." .

schema:genre a owl:ObjectProperty ;
    rdfs:comment "[Schema.org] Genre of the creative work or group." .

schema:recordLabel a owl:ObjectProperty ;
    rdfs:comment "[Schema.org] The record label for a music release." .

mh:CoverRecording a owl:Class ;
    rdfs:label "Cover Recording" ;
    rdfs:comment "An audio recording of a composition made by an artist who is not the original composer." ;
    rdfs:subClassOf mo:Signal .

mh:Organisation a owl:Class ;
    rdfs:label "Organisation" ;
    rdfs:comment "An organisation founded by or associated with an artist." .

mh:Persona a owl:Class ;
    rdfs:label "Persona" ;
    rdfs:comment "A stage persona or alter ego adopted by an artist (e.g., Ziggy Stardust)." .

