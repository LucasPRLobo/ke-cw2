mh:hasEra a owl:ObjectProperty ;
    rdfs:label "has era" ;
    rdfs:comment "Links a musical work to the historical era in which it was composed." ;
    rdfs:domain mo:MusicalWork ;
    rdfs:range mh:Era .

mh:hasMember a owl:ObjectProperty ;
    rdfs:label "has member" ;
    rdfs:comment "Links a group to a member artist." ;
    rdfs:domain mo:MusicGroup ;
    rdfs:range mo:SoloMusicArtist .

mh:hasMusicalPeriod a owl:ObjectProperty ;
    rdfs:label "has musical period" ;
    rdfs:comment "Links an artist to a historical musical period." ;
    rdfs:domain mo:MusicArtist ;
    rdfs:range mh:Era .

mh:hasTrack a owl:ObjectProperty ;
    rdfs:label "has track" ;
    rdfs:comment "Links an album to its tracks." ;
    rdfs:domain mo:Release ;
    rdfs:range mo:Track .

mh:influencedBy a owl:ObjectProperty ;
    rdfs:label "influenced by" ;
    rdfs:comment "Links an artist to another artist who influenced their work or style." ;
    rdfs:domain mo:MusicArtist ;
    rdfs:range mo:MusicArtist .

mh:internationalCollaboration a owl:ObjectProperty ;
    rdfs:label "international collaboration" ;
    rdfs:comment "A collaboration between two artists who originate from different countries." ;
    rdfs:subPropertyOf mo:collaborated_with .

mh:pioneerOf a owl:ObjectProperty ;
    rdfs:label "pioneer of" ;
    rdfs:comment "Links an artist to a genre they pioneered." ;
    rdfs:domain mo:MusicArtist ;
    rdfs:range mo:Genre .

mh:playsInstrument a owl:ObjectProperty ;
    rdfs:label "plays instrument" ;
    rdfs:comment "Links an artist to an instrument they play." ;
    rdfs:domain mo:MusicArtist ;
    rdfs:range mo:Instrument .

mh:primaryInstrument a owl:ObjectProperty ;
    rdfs:label "primary instrument" ;
    rdfs:comment "The lead or most prominent instrument used in a track or by an artist." ;
    rdfs:subPropertyOf mo:instrument .

mh:producedBy a owl:ObjectProperty ;
    rdfs:label "produced by" ;
    rdfs:comment "Links an album to its producer." ;
    rdfs:domain mo:Release ;
    rdfs:range mo:MusicArtist .

mh:realName a owl:DatatypeProperty ;
    rdfs:label "real name" ;
    rdfs:comment "The birth name or legal name of an artist." ;
    rdfs:domain mo:SoloMusicArtist .

mh:releaseDate a owl:DatatypeProperty ;
    rdfs:label "release date" ;
    rdfs:comment "The date an album was released." ;
    rdfs:domain mo:Release .

mh:released a owl:ObjectProperty ;
    rdfs:label "released" ;
    rdfs:comment "Links an artist to an album they released." ;
    rdfs:domain mo:MusicArtist ;
    rdfs:range mo:Release .

mh:signedTo a owl:ObjectProperty ;
    rdfs:label "signed to" ;
    rdfs:comment "Links an artist or band to the record label they are contracted with." ;
    rdfs:domain mo:MusicArtist ;
    rdfs:range mo:Label ;
    rdfs:subPropertyOf schema:affiliation .

mh:subgenreOf a owl:ObjectProperty ;
    rdfs:label "subgenre of" ;
    rdfs:comment "Links a subgenre to its parent genre." ;
    rdfs:domain mo:Genre ;
    rdfs:range mo:Genre .

