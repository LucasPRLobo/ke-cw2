@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix mb: <http://musicbrainz.org/artist/> .
@prefix mb_recording: <http://musicbrainz.org/recording/> .
@prefix mh: <http://example.org/music-history/> .
@prefix mo: <http://purl.org/ontology/mo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

mh: a owl:Ontology ;
    rdfs:label "Music History & Heritage Knowledge Graph" ;
    rdfs:comment "An ontology for representing music history, extending the Music Ontology and Schema.org. Covers artists, compositions, albums, genres, instruments, awards, and record labels across all eras from medieval to modern." .

mh:AwardWinningArtist a owl:Class ;
    rdfs:label "Award-Winning Artist" ;
    rdfs:comment "Defined class: a MusicArtist who has won at least one MusicAward. Inferred by a reasoner from wonAward triples." ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( mo:MusicArtist [ a owl:Restriction ;
                        owl:onProperty mh:wonAward ;
                        owl:someValuesFrom mh:MusicAward ] ) ] .

mh:Composer a owl:Class ;
    rdfs:label "Composer" ;
    rdfs:comment "A person who writes or composes musical works. Modelled as a subclass for query convenience; see ProducerArtist defined class for inference-based role assignment." ;
    rdfs:subClassOf mo:MusicArtist .

mh:IndependentLabel a owl:Class ;
    rdfs:label "Independent Label" ;
    rdfs:comment "A record label that operates without the funding of major record labels." ;
    rdfs:subClassOf mo:Label .

mh:InternationalCollaborator a owl:Class ;
    rdfs:label "International Collaborator" ;
    rdfs:comment "Defined class: a MusicArtist who has collaborated with at least one other MusicArtist. Inferred by a reasoner from collaboratedWith triples." ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( mo:MusicArtist [ a owl:Restriction ;
                        owl:onProperty mh:collaboratedWith ;
                        owl:someValuesFrom mo:MusicArtist ] ) ] .

mh:MultinationalBand a owl:Class ;
    rdfs:label "Multinational Band" ;
    rdfs:comment "A music group whose members originate from more than one distinct country." ;
    rdfs:subClassOf schema:MusicGroup .

mh:Musician a owl:Class ;
    rdfs:label "Musician" ;
    rdfs:comment "A person who performs music, typically as an instrumentalist or vocalist." ;
    rdfs:subClassOf mo:MusicArtist .

mh:Producer a owl:Class ;
    rdfs:label "Producer" ;
    rdfs:comment "A person who oversees and directs the recording and production of music. See ProducerArtist defined class for reasoner-inferred assignment." ;
    rdfs:subClassOf mo:MusicArtist .

mh:ProducerArtist a owl:Class ;
    rdfs:label "Producer Artist" ;
    rdfs:comment "Defined class: a MusicArtist who has produced at least one Release. Inferred by a reasoner from produced triples. Note: this addresses the CW1 feedback about roles vs types — ProducerArtist is defined by what the artist does, not by assertion." ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( mo:MusicArtist [ a owl:Restriction ;
                        owl:onProperty mh:produced ;
                        owl:someValuesFrom mo:Release ] ) ] .

mh:activeDuring a owl:ObjectProperty ;
    rdfs:label "active during" ;
    rdfs:comment "Links an artist to the historical era during which they were active." ;
    rdfs:domain mo:MusicArtist ;
    rdfs:range mh:Era .

mh:activeIn a owl:ObjectProperty ;
    rdfs:label "active in" ;
    rdfs:comment "Links an artist to a country where they were professionally active." ;
    rdfs:domain mo:MusicArtist ;
    rdfs:range schema:Country .

mh:albumGrouping a owl:ObjectProperty ;
    rdfs:label "album grouping" ;
    rdfs:comment "Links an album to a named album group." ;
    rdfs:domain mo:Release ;
    rdfs:range mh:AlbumGroup .

mh:alterEgo a owl:ObjectProperty ;
    rdfs:label "alter ego" ;
    rdfs:comment "Links an artist to a stage persona." ;
    rdfs:domain mo:MusicArtist ;
    rdfs:range mh:Persona .

<http://example.org/music-history/artist/Heroes__1977_> a mo:MusicArtist ;
    rdfs:label "Heroes (1977)" ;
    mh:albumGrouping <http://example.org/music-history/album_group/Berlin_Trilogy> .

mh:birthPlace a owl:DatatypeProperty ;
    rdfs:label "birth place" ;
    rdfs:comment "The city or area where an artist was born." ;
    rdfs:domain mo:SoloMusicArtist .

mh:composed a owl:ObjectProperty ;
    rdfs:label "composed" ;
    rdfs:comment "Links a composer to a musical work they composed." ;
    rdfs:domain mo:MusicArtist ;
    rdfs:range mh:MusicalWork .

mh:compositionDate a owl:DatatypeProperty ;
    rdfs:label "composition date" ;
    rdfs:comment "The date a musical work was composed, distinct from recording or release date." ;
    rdfs:domain mh:MusicalWork .

mh:countryOfOrigin a owl:ObjectProperty ;
    rdfs:label "country of origin" ;
    rdfs:comment "Links an artist, member, or band to their country of origin or formation." ;
    rdfs:domain mo:MusicArtist ;
    rdfs:range schema:Country ;
    rdfs:subPropertyOf schema:nationality .

mh:covers a owl:ObjectProperty ;
    rdfs:label "covers" ;
    rdfs:comment "Links a cover recording to the original musical work." ;
    rdfs:domain mh:CoverRecording ;
    rdfs:range mo:MusicalWork .

mh:duration a owl:DatatypeProperty ;
    rdfs:label "duration" ;
    rdfs:comment "The duration of a track in milliseconds." ;
    rdfs:domain mo:Track .

mh:founded a owl:ObjectProperty ;
    rdfs:label "founded" ;
    rdfs:comment "Links an artist to an organisation they founded." ;
    rdfs:domain mo:MusicArtist ;
    rdfs:range mh:Organisation .

